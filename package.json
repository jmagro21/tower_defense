    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "phaser": "^3.70.0",
    "socket.io-client": "^4.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
