{
  "name": "tower-defense-multiplayer",
  "version": "1.0.0",
  "description": "Jeu Tower Defense multijoueur en temps réel",
  "main": "server/index.js",
  "scripts": {
    "start": "node scripts/copy-libs.js && node server/index.js",
    "dev": "node scripts/copy-libs.js && nodemon server/index.js",
